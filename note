    // const cad = localStorage.getItem("1")
    // console.log(cad)
    // // taskForm.reset()
    // loadPage()

    // let data = new FormData(taskForm)
    // formData = Object.fromEntries(data)
    // localStorage.setItem("counter", counter++)
    // localStorage.setItem(counter, JSON.stringify(formData))
    // loadPage()

    
    let data = new FormData(taskForm)
    formData = Object.fromEntries(data)
    localStorage.setItem("counter", ++counter)
    localStorage.setItem(counter, JSON.stringify(formData))
    loadPage()


}

