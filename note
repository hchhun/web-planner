counter = 0
const doPlusBtn = document.getElementById('doPlus')
const doTaskContainer = document.querySelector('#doTaskContainer')
// const taskTitle = document.getElementById('taskTitle')
// const taskPriority = document.getElementById('taskPriority')
const taskForm = document.getElementById("taskForm")
const addBtn = document.getElementById('testbutton')

let doTaskList = []

function loadPage() {
    if (localStorage.getItem("counter") == null) {
        localStorage.setItem("counter", 0)
    }
    else counter = parseInt(localStorage.getItem("counter"))

    for (let i = 1; i <= counter; i++) {
        tempTask = JSON.parse(localStorage.getItem(i))
        switch(tempTask["taskPriority"]){
            case "do":
                doTaskList += `<div class="task doTask">
                                    <button class="iconBtn"><i class="fa-regular fa-square"></i></button>
                                    ${tempTask["taskTitle"]}
                                    <button class="iconBtn"><i class="fa-regular fa-trash-can"></i></button>
                                </div>`
                break;
            // case "schedule":
                
            // case "delegate":
            // case "delete":
        }
        
    }

    doTaskContainer.innerHTML = doTaskList
}

loadPage()

function addTask(e) {
    // e.preventDefault()
